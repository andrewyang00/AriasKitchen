# Copy to .env and fill in for real generation/moderation. Run with:
#   npm start
# (loads .env automatically via --env-file-if-exists; no dotenv package needed)

# Port the backend HTTP server listens on.
PORT=8787

# OpenAI API key with image-generation (gpt-image-1) + moderation access.
# Leave unset to run fully in MOCK mode: generateCharacterPoseSet() returns
# the existing default Aria art instead of calling OpenAI, and moderation
# fails CLOSED (every upload is held with status "flagged" for manual
# review) unless MODERATION_MOCK_PASS is also set below.
OPENAI_API_KEY=

# DEV ONLY. When "true" and OPENAI_API_KEY is unset, skips the fail-closed
# moderation default so local end-to-end testing doesn't require a real key.
# Never set this anywhere that accepts uploads from the public -- this
# product processes photos of likely-minors and moderation must never be
# silently bypassed outside a developer's own machine.
MODERATION_MOCK_PASS=false

# Shared secret required (as an `x-admin-token` header) to approve a
# flagged character via POST /api/admin/characters/:token/approve.
ADMIN_TOKEN=change-me

# Where uploaded photos and generated pose art are stored on disk.
DATA_DIR=./data

# How long (ms) an uploaded source photo may live on disk before the
# worker's retention sweep deletes it, regardless of job outcome.
PHOTO_RETENTION_MS=86400000

# Base URL the frontend (pancake-game) should call. Informational here --
# set this as window.ARIA_CHARACTER_API_BASE in the game's own HTML, not
# read by this backend itself.
# ARIA_CHARACTER_API_BASE=http://localhost:8787
